# ─────────── Database ───────────
MONGO_USER=aideploy
MONGO_PASSWORD=change_me_in_prod
MONGO_DB=aideploy
MONGO_URI=mongodb://aideploy:change_me_in_prod@localhost:27017/aideploy?authSource=admin

# ─────────── Redis ───────────
REDIS_PASSWORD=change_me_in_prod

# ─────────── RabbitMQ ───────────
RABBITMQ_USER=aideploy
RABBITMQ_PASSWORD=change_me_in_prod

# ─────────── JWT ───────────
JWT_SECRET_KEY=generate_a_strong_random_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────── AWS ───────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-deploy-models-prod
ECR_REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com

# ─────────── Grafana ───────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_in_prod
